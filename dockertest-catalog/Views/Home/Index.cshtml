@{
    ViewData["Title"] = "Release Kataloğu";
}

<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-catalog mb-4 py-3">
        <div class="container">
            <span class="navbar-brand mb-0 h1 fs-5 text-white">Release Kataloğu</span>
            <span class="badge bg-secondary">Agent buradan .tar.gz okur</span>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card-catalog p-4">
                    <h2 class="h5 mb-3">Sürüm Yükle</h2>
                    <p class="text-muted small">Docker image arşivini yükle. Dosya adı <code>dockertest-x.y.z.tar.gz</code> formatında olmalı.</p>

                    <div class="upload-zone mb-3" id="upload-zone">
                        <input type="file" id="file-input" accept=".tar.gz,.tgz" hidden />
                        <div class="upload-icon mb-2">📦</div>
                        <div>Sürükle bırak veya <button type="button" class="btn btn-link p-0 align-baseline" id="pick-file">dosya seç</button></div>
                        <div class="text-muted small mt-1" id="selected-file">Henüz dosya seçilmedi</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted" for="version-input">Sürüm (opsiyonel)</label>
                        <input type="text" class="form-control form-control-catalog" id="version-input" placeholder="1.2.3 — dosya adından da okunur" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted" for="name-input">Görünen ad (opsiyonel)</label>
                        <input type="text" class="form-control form-control-catalog" id="name-input" placeholder="Örn: İlk test sürümü" />
                    </div>

                    <div class="progress mb-2 d-none" id="upload-progress-wrap">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" id="upload-progress" style="width: 0%"></div>
                    </div>
                    <p class="small text-muted d-none" id="upload-status"></p>

                    <button type="button" class="btn btn-accent w-100" id="upload-btn" disabled>Yükle</button>

                    <hr class="border-secondary my-4" />
                    <p class="text-muted small mb-0">
                        CLI ile oluşturmak için:<br />
                        <code>docker save IMAGE:TAG | gzip &gt; dockertest-1.0.0.tar.gz</code>
                    </p>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card-catalog p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Yayındaki Sürümler</h2>
                        <button type="button" class="btn btn-sm btn-outline-light" id="refresh-btn">Yenile</button>
                    </div>
                    <div id="releases-list">
                        <p class="text-muted">Yükleniyor...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/catalog.js" asp-append-version="true"></script>
</body>
</html>
