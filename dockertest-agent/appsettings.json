{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "ImageName": "ghcr.io/hssn2/dockertest",
    "AppHostPort": 80,
    "AppContainerPort": 8080,
    "CandidateHostPort": 8081,
    "ContainerNamePrefix": "dockertest_",
    "GitHubOwner": "Hssn2",
    "GitHubRepo": "dockertest",
    "GitHubToken": "",
    "HealthPath": "/health",
    "HealthCheckRetries": 15,
    "HealthCheckIntervalSeconds": 2
  }
}
