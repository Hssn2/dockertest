@{
    ViewData["Title"] = "Güncelleme Agent";
    var agentVersion = Environment.GetEnvironmentVariable("APP_VERSION") ?? "dev";
}

<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hasan Günay</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-agent mb-4 py-3">
        <div class="container">
            <span class="navbar-brand mb-0 h1 fs-5 text-white">Hasan Günay · Güncelleme Agent</span>
            <div>
                <span class="badge bg-info me-2">Agent v@agentVersion</span>
                <span class="badge bg-secondary" id="active-version-badge">Uygulama: —</span>
            </div>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card-agent p-4 mb-4">
                    <h2 class="h5 mb-3">Güncelleme Süreci</h2>
                    <div class="progress mb-3">
                        <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
                    </div>
                    <p id="progress-message" class="mb-3 text-muted">Hazır</p>

                    <div id="phase-list">
                        <div class="phase-step" data-phase="PullingImage"><span class="phase-dot"></span>Image indiriliyor</div>
                        <div class="phase-step" data-phase="StartingCandidate"><span class="phase-dot"></span>Aday container başlatılıyor (8081)</div>
                        <div class="phase-step" data-phase="HealthCheckingCandidate"><span class="phase-dot"></span>Aday sağlık kontrolü</div>
                        <div class="phase-step" data-phase="StoppingCurrent"><span class="phase-dot"></span>Mevcut sürüm durduruluyor</div>
                        <div class="phase-step" data-phase="StartingProduction"><span class="phase-dot"></span>Port 80'de yeni sürüm başlatılıyor</div>
                        <div class="phase-step" data-phase="HealthCheckingProduction"><span class="phase-dot"></span>Canlı sağlık kontrolü</div>
                        <div class="phase-step" data-phase="Completed"><span class="phase-dot"></span>Tamamlandı</div>
                    </div>

                    <div class="log-box mt-3" id="log-box"></div>
                </div>

                <div class="card-agent p-4">
                    <h2 class="h5 mb-3">Yayınlanmış Sürümler</h2>
                    <div id="releases-list">
                        <p class="text-muted">Yükleniyor...</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card-agent p-4">
                    <h2 class="h5 mb-3">Container Geçmişi</h2>
                    <p class="text-muted small">Eski container'lar silinmez. Sorun olursa buradan geri dönebilirsin.</p>
                    <div id="containers-list">
                        <p class="text-muted">Yükleniyor...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/agent.js" asp-append-version="true"></script>
</body>
</html>
