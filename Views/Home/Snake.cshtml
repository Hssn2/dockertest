@{
    ViewData["Title"] = "Snake";
}

<div class="text-center page-hero snake-page">
    <h1 class="h3 mb-2">Snake</h1>
    <p class="text-muted small mb-3">Yön tuşları ile oyna</p>
    <p id="snake-score" class="snake-score mb-2">Skor: 0</p>
    <p id="snake-status" class="snake-status mb-3">Hazır</p>
    <canvas id="snake-canvas" class="snake-canvas" width="400" height="400" tabindex="0"></canvas>
    <div class="mt-3">
        <button type="button" id="snake-start" class="btn btn-accent btn-sm">Başla / Yeniden</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/snake.js" asp-append-version="true"></script>
}
